{
  "name": "asset-librarian",
  "version": "1.0.0",
  "private": true,
  "description": "3D model asset manager — scan, catalog, preview, and validate FBX/OBJ/GLB/GLTF assets",
  "author": "Asset Librarian Team",
  "license": "MIT",
  "homepage": "https://github.com/asset-librarian/asset-librarian",
  "main": "electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && npx electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --win --config electron-builder.yml",
    "build:mac": "npm run build:renderer && electron-builder --mac --config electron-builder.yml",
    "build:linux": "npm run build:renderer && electron-builder --linux --config electron-builder.yml",
    "build:all": "npm run build:renderer && electron-builder --win --mac --linux --config electron-builder.yml",
    "pack": "npm run build:renderer && electron-builder --dir --config electron-builder.yml",
    "dist": "npm run build:renderer && electron-builder --win --config electron-builder.yml --publish always",
    "release": "npm run build:renderer && electron-builder --win --mac --config electron-builder.yml --publish always",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.11.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^42.2.0",
    "electron-builder": "^25.1.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
